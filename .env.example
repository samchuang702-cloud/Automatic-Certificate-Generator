# 應用程式
APP_NAME=Certificate Generator System
APP_ENV=development

# 本機 SQLite 資料庫
DATABASE_URL=sqlite:///./storage/database/certificates.db

# 儲存資料夾
UPLOAD_DIR=storage/uploads
GENERATED_DIR=storage/generated
GENERATED_RETENTION_DAYS=90
TEMPLATE_DIR=app/templates

# 證書模板
CERTIFICATE_TEMPLATE_PATH=storage/templates/certificate_template.pptx
CERTIFICATE_WORD_TEMPLATE_PATH=storage/templates/cfd_certificate_template.doc

# JWT 設定
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_EXPIRE_MINUTES=480

# CORS 允許的源 (開發環境)
# 開發環境: localhost 開發源
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001,http://127.0.0.1:3000,http://127.0.0.1:8000,http://127.0.0.1:8001

# 生產環境: 替換為實際的 HTTPS 域名
# CORS_ORIGINS=https://yourhospital.com,https://app.yourhospital.com

# 證書 PDF 背景 (可選)
CERTIFICATE_PDF_BACKGROUND_PATH=storage/templates/cfd_certificate_background.pdf
USE_WORD_CERTIFICATE_RENDERER=True
